# NeuroGate — variables de entorno del servicio (Fases C y D).
# Copia este archivo a `.env` y rellena valores reales. El `.env` NO se versiona.
# Todas las variables usan el prefijo NEUROGATE_.

# --- Fase C (servicio + JWT) ---

# Secreto para firmar los JWT (HS256). USA UNO LARGO Y ALEATORIO (>=32 bytes).
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
NEUROGATE_JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-bytes-min

# Algoritmo de firma del JWT (por defecto HS256).
NEUROGATE_JWT_ALGORITHM=HS256

# Minutos de validez de cada token emitido.
NEUROGATE_TOKEN_EXPIRE_MINUTES=30

# Modo clínico: habilita el scope sensible read:raw_signal. Desactivado por defecto.
NEUROGATE_CLINICAL_MODE=false

# Semilla determinista para la señal simulada y el decoder.
NEUROGATE_SEED=0

# --- Fase D (hardening) ---

# Master key del cifrado por app (HKDF). NUNCA en código; en producción, un KMS.
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(48))"
NEUROGATE_MASTER_KEY=cambia-esto-por-una-master-key-larga-y-aleatoria

# Ventana anti-replay (segundos): sobres con timestamp fuera de ella se rechazan.
NEUROGATE_REPLAY_WINDOW_SECONDS=30

# Rotación de claves de cifrado: cada cuántos requests rotar (0 = no rotar).
NEUROGATE_KEY_ROTATION_EVERY=0
# Versiones de clave anteriores aún aceptadas durante la rotación.
NEUROGATE_RETAINED_KEY_VERSIONS=1

# Log auditado firmado (Ed25519). La privada va por archivo IGNORADO (o KMS);
# la pública se puede publicar/versionar. Si no existen, el servicio las genera.
NEUROGATE_AUDIT_PRIVATE_KEY_PATH=keys/audit_ed25519_private.pem
NEUROGATE_AUDIT_PUBLIC_KEY_PATH=keys/audit_ed25519_public.pem

# Anomalías sobre telemetría real: requests por app a aprender antes de vigilar,
# y factor de pico de tasa (×N sobre la típica) que dispara cuarentena.
NEUROGATE_ANOMALY_BASELINE_REQUESTS=30
NEUROGATE_ANOMALY_RATE_SPIKE_FACTOR=10

# TLS de desarrollo: cert y clave para servir HTTPS/WSS. Genera con:
#   python scripts/gen_cert.py
# y arranca: uvicorn neurogate.service:app --ssl-certfile certs/dev_cert.pem \
#            --ssl-keyfile certs/dev_key.pem
NEUROGATE_TLS_CERTFILE=certs/dev_cert.pem
NEUROGATE_TLS_KEYFILE=certs/dev_key.pem
