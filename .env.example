# NeuroGate — variables de entorno del servicio (Fase C).
# Copia este archivo a `.env` y rellena valores reales. El `.env` NO se versiona.
# Todas las variables usan el prefijo NEUROGATE_.

# Secreto para firmar los JWT (HS256). USA UNO LARGO Y ALEATORIO (>=32 bytes).
# Genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
NEUROGATE_JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-bytes-min

# Algoritmo de firma del JWT (por defecto HS256).
NEUROGATE_JWT_ALGORITHM=HS256

# Minutos de validez de cada token emitido.
NEUROGATE_TOKEN_EXPIRE_MINUTES=30

# Modo clínico: habilita el scope sensible read:raw_signal. Desactivado por defecto.
NEUROGATE_CLINICAL_MODE=false

# Semilla determinista para la señal simulada y el decoder.
NEUROGATE_SEED=0
